## This is a sample .env file for the Paper PHP Framework.
## Copy this file to .env and update the values as needed.

APP_ENV=development
APP_DEBUG=true
APP_DOMAIN=localhost
APP_URL=http://127.0.0.1:8091
APP_NAME="Paper-PHPFramework" # Change this to your desired application name.
PAGE_LOADER_ENABLED=false
# In production, set APP_URL to your canonical https:// domain (used by sitemap.xml and robots.txt).

# Optional: shown on support / legal pages (mailto links)
APP_SUPPORT_EMAIL=
APP_LEGAL_EMAIL=

# Sitemap size (static pages + genre pages + catalogue). Max 50000 per Google single file.
SITEMAP_MAX_URLS=50000

# ads.txt: Google Ad Manager / AdSense seller ID (with or without pub- prefix). If storage/seo/ads.txt
# exists, that file is served instead and this variable is ignored.
GOOGLE_ADS_PUBLISHER_ID=

# Login users are loaded from the database.
# Run `php cli.php install` to seed the default admin user.
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=paper_phpframework # Change this to your desired database name.
DB_USER=root # Change this to your database username.
DB_PASSWORD= # Change this to your database password.

# TMDB API credentials. Prefer the v4 Read Access Token as a Bearer token.
TMDB_ACCESS_TOKEN=
TMDB_API_KEY=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
# TMDB CDN base (path = /t/p/{size}/filename). Use original for full resolution.
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/original
TMDB_BACKDROP_BASE_URL=https://image.tmdb.org/t/p/original
TMDB_LANGUAGE=en-US
TMDB_TIMEOUT=12

# Importer images: false = store TMDB URLs only (no disk usage). true = download WebP variants locally.
TMDB_DOWNLOAD_IMAGES=false
# WebP quality used when downloading images (40..92). Lower = faster + smaller.
TMDB_WEBP_QUALITY=88
TMDB_POSTER_WIDTHS=342,500,780
TMDB_BACKDROP_WIDTHS=780,1280
TMDB_WEBP_QUALITY_THUMB=82
TMDB_WEBP_QUALITY_CARD=85
TMDB_WEBP_QUALITY_HERO=88

# --- Redis (Predis = pure PHP, no phpredis extension needed; Redis server on 127.0.0.1:6379) ---
# Run: composer install
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2.0
# Prefix for application cache keys (homepage payload, etc.)
REDIS_PREFIX=vexio

# Store PHP sessions in Redis (recommended on real domains; avoids disk I/O per request).
REDIS_SESSION_ENABLED=true
REDIS_SESSION_DB=0
REDIS_SESSION_PREFIX=vexio:sess:

# Homepage DB payload cache (seconds). Lower after bulk imports or when freshness matters.
HOME_PAGE_CACHE_ENABLED=true
HOME_PAGE_CACHE_TTL=120

# Vexio streaming scraper bridge. Start the scraper from embed-api with `npm run start:dev`.
EMBED_API_ENABLED=true
EMBED_API_URL=https://embed.vexio.asia
EMBED_API_CONNECT_TIMEOUT=5
EMBED_API_TIMEOUT=180
EMBED_API_SOURCE_CACHE_TTL=1800

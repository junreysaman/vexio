API_PORT=8787
BIND_HOST=0.0.0.0

# Required for TMDB metadata lookup. Use either one key or a JSON array.
TMDB_API_KEY=
# TMDB_API_KEYS=["key1","key2"]

# Vexio production defaults.
DEFAULT_PROVIDERS=dahmermovies
ENABLE_DAHMERMOVIES_PROVIDER=true
ENABLE_4KHDHUB_PROVIDER=false
ENABLE_PROXY=true

# Optional provider/runtime settings.
FEBBOX_COOKIES=
DISABLE_CACHE=false
DISABLE_URL_VALIDATION=false
